!.env.example
# =================================================================
# API E-COMMERCE - TEMPLATE DE VARIÁVEIS DE AMBIENTE
# =================================================================
# Instruções: Copie este arquivo e renomeie para '.env'
# Preencha os valores abaixo de acordo com seu ambiente local.

# -----------------------------------------------------------------
# BANCO DE DADOS (SQL Server)
# -----------------------------------------------------------------
# Exemplo para LocalDB ou SQL Express:
# ConnectionStrings__DefaultConnection="Server=localhost;Database=ApiEcommerce;Trusted_Connection=True;TrustServerCertificate=True;"
# Exemplo com Usuário e Senha:
ConnectionStrings__DefaultConnection="Server=localhost;Database=ApiEcommerce;User Id=seu_usuario;Password=sua_senha;TrustServerCertificate=True;"

# -----------------------------------------------------------------
# SEGURANÇA (JWT - JSON Web Token)
# -----------------------------------------------------------------
# JWT__Key deve ser uma string aleatória com pelo menos 32 caracteres
Jwt__Key="COLOQUE_AQUI_UMA_CHAVE_SECRETA_LONGA_E_SEGURA"
Jwt__Issuer="ApiEcommerce"
Jwt__Audience="ApiEcommerce"

# -----------------------------------------------------------------
# AMBIENTE E LOGGING
# -----------------------------------------------------------------
# Valores comuns: Development, Staging, Production
ASPNETCORE_ENVIRONMENT="Development"

# Níveis de Log: Verbose, Debug, Information, Warning, Error, Fatal
Logging__LogLevel__Default="Information"
Logging__LogLevel__Microsoft__AspNetCore="Warning"

# ----------------------------------------------------------------
# CONFIGURAÇÕES EXTRAS (Se houver)
# ----------------------------------------------------------------
# Exemplo: API_EXTERNAL_SERVICE_KEY="sua_chave_aqui"


